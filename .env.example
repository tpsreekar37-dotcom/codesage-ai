# Backend Configuration
PORT=8000
SECRET_KEY=your_super_secret_key_change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_here
POSTGRES_DB=ai_code_review_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
# For local running without docker-compose, set host to localhost:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres_password_here@localhost:5432/ai_code_review_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password_here@db:5432/ai_code_review_db

# Redis Caching & Rate Limiting
REDIS_HOST=cache
REDIS_PORT=6379
# For local running without docker-compose, set host to localhost:
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=redis://cache:6379/0

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Upload/Clone Directories
UPLOAD_DIR=/app/data/uploads
CLONE_DIR=/app/data/cloned
MAX_UPLOAD_SIZE_MB=25

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
